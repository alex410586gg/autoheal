_G.AutoHealEnabled = not (_G.AutoHealEnabled or false)

if _G.AutoHealConnection == nil then
    local HealRemote = game:GetService("ReplicatedStorage")
        :WaitForChild("Remotes")
        :WaitForChild("Heal")

    local RunService = game:GetService("RunService")

    _G.AutoHealConnection = RunService.Heartbeat:Connect(function()
        if _G.AutoHealEnabled then
            HealRemote:FireServer()
        end
    end)
end

print("Auto Heal:", _G.AutoHealEnabled and "ON" or "OFF")
